{
  "name": "TunaScript",
  "scopeName": "source.tuna",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#cast-import" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#builtins" },
    { "include": "#function-def" },
    { "include": "#function-call" },
    { "include": "#booleans" },
    { "include": "#null" },
    { "include": "#numbers" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "match": "><>.*$",
      "name": "comment.line.tuna"
    },

    "strings": {
      "name": "string.quoted.double.tuna",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "match": "\\\\[\"\\\\ntr]",
          "name": "constant.character.escape.tuna"
        }
      ]
    },

    "cast-import": {
      "patterns": [
        {
          "comment": "from \"path\" catch ...",
          "match": "\\b(from)\\s+(\"[^\"]*\")\\s+(catch)\\b",
          "captures": {
            "1": { "name": "keyword.control.import.tuna" },
            "2": { "name": "string.quoted.double.tuna" },
            "3": { "name": "keyword.control.import.tuna" }
          }
        },
        {
          "comment": "cast keyword before a declaration",
          "match": "\\b(cast)\\b",
          "name": "keyword.control.export.tuna"
        }
      ]
    },

    "keywords": {
      "match": "\\b(if|else|while|for|in|break|continue|serve|shore|catch|anchor|new|typeof|and|or)\\b",
      "name": "keyword.control.tuna"
    },

    "types": {
      "match": "(?<=:)\\s*(number|string|bool|array|object|function|void|null|\\[\\]number|\\[\\]string|\\[\\]bool)",
      "captures": {
        "1": { "name": "support.type.tuna" }
      }
    },

    "builtins": {
      "patterns": [
        {
          "comment": "namespace objects: math, string, array",
          "match": "\\b(math|string|array)\\.(floor|ceil|round|abs|min|max|pow|sqrt|rand|randInt|pi|e|upper|lower|trim|split|contains|replace|startsWith|endsWith|repeat|push|pop|first|last|slice|sort|join|reverse)\\b",
          "captures": {
            "1": { "name": "support.class.tuna" },
            "2": { "name": "support.function.tuna" }
          }
        },
        {
          "comment": "global builtin functions",
          "match": "\\b(bubble|typeOf|toNumber|toString|len)(?=\\s*\\()",
          "name": "support.function.builtin.tuna"
        }
      ]
    },

    "function-def": {
      "comment": "swim functionName — highlight the name after swim",
      "match": "\\b(swim)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
      "captures": {
        "1": { "name": "keyword.control.tuna" },
        "2": { "name": "entity.name.function.tuna" }
      }
    },

    "function-call": {
      "comment": "anyName( — highlight user-defined function calls",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()",
      "name": "entity.name.function.tuna"
    },

    "booleans": {
      "match": "\\b(true|false)\\b",
      "name": "constant.language.boolean.tuna"
    },

    "null": {
      "match": "\\bnil\\b",
      "name": "constant.language.null.tuna"
    },

    "numbers": {
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b",
      "name": "constant.numeric.tuna"
    },

    "operators": {
      "match": "(==|!=|<=|>=|\\+\\+|--|\\+=|-=|\\*=|/=|[+\\-*/%=<>!])",
      "name": "keyword.operator.tuna"
    }
  }
}